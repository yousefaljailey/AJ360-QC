# Copy this file to .env for local development
# Set these as environment variables in Railway dashboard for production

# Server
PORT=3000

# Auth — change JWT_SECRET to a long random string in production
JWT_SECRET=change-this-to-a-long-random-secret

# Admin account
ADMIN_EMAIL=algaileyy@aljazeera.net

# Email (Office 365 SMTP) — required for user approval emails
EMAIL_PASS=your-office365-password

# Public URL — used in approval email links (set to your Railway domain)
# e.g. https://aj360-qc.up.railway.app
BASE_URL=http://localhost:3000

# Persistent storage root — on Railway, mount a volume and set this to the mount path
# e.g. /data  (Railway volume mounted at /data)
# Leave blank locally — defaults to the project directory
PERSIST_DIR=
